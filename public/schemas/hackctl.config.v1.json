{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hackctl.dev/schemas/hackctl.config.v1.json",
  "title": "hackctl.config.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "template",
    "services",
    "share"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "template": {
      "type": "string",
      "minLength": 1
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/service"
      }
    },
    "share": {
      "$ref": "#/$defs/share"
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "cwd",
        "run",
        "port"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "cwd": {
          "type": "string",
          "minLength": 1
        },
        "run": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "envFile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "share": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultService": {
          "type": "string",
          "minLength": 1
        },
        "defaultPort": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        }
      }
    }
  }
}
